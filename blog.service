[Unit]
Description=Midnight Library Blog
After=network.target

[Service]
Type=simple
User=blog
Group=blog
WorkingDirectory=/opt/blog
ExecStart=/usr/bin/java -jar /opt/blog/blog-1.0.0.jar
Restart=on-failure
RestartSec=5

# Security hardening
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/opt/blog/data
NoNewPrivileges=true

# Logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=blog

[Install]
WantedBy=multi-user.target
